# compinit must run before fzf-tab and other completion plugins.
autoload -Uz compinit
if [[ -n ${ZDOTDIR:-$HOME}/.zcompdump(#qN.mh+24) ]]; then
  compinit
else
  compinit -C
fi

# Load antidote without spawning brew on every shell start.
if [[ -r /opt/homebrew/opt/antidote/share/antidote/antidote.zsh ]]; then
  source /opt/homebrew/opt/antidote/share/antidote/antidote.zsh
elif [[ -r /usr/local/opt/antidote/share/antidote/antidote.zsh ]]; then
  source /usr/local/opt/antidote/share/antidote/antidote.zsh
else
  source "$(brew --prefix)/opt/antidote/share/antidote/antidote.zsh"
fi
antidote load

autoload -Uz promptinit
promptinit

prompt pure

# Disable flow control commands (keeps C-s from freezing everything).
if [[ -o interactive && -t 0 ]]; then
  stty start undef
  stty stop undef
fi

# Allow [ or ] whatever you want
unsetopt nomatch

## Command history configuration
# Set history file location if not already set
: "${HISTFILE:=$HOME/.zsh_history}"

# Configure history size limits
HISTSIZE=50000
SAVEHIST=50000

# History options
setopt extended_history        # Record timestamp and duration of commands
setopt hist_expire_dups_first  # Delete duplicates first when HISTFILE size exceeds HISTSIZE
setopt hist_ignore_dups        # Don't record duplicated commands
setopt hist_ignore_space       # Don't record commands starting with a space
setopt hist_verify             # Show command with history expansion before running it
setopt inc_append_history      # Add commands to HISTFILE in order of execution
setopt share_history           # Share command history between sessions

# Sourcing of other files
source "$HOME/.laptop/dotfiles/zsh/aliases"
source "$HOME/.laptop/dotfiles/zsh/functions"

eval "$(mise activate zsh)"

# fzf shell integration (Ctrl+R history, Ctrl+T files, Alt+C dirs)
source <(fzf --zsh)

eval "$(zoxide init zsh)"

# bun completions
[ -s "/Users/javier.cadiz/.bun/_bun" ] && source "/Users/javier.cadiz/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"
