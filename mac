#!/bin/sh

set -eu

ROOT="$(cd -- "$(dirname -- "$0")" && pwd)"

link_file() {
  ln -snf "$1" "$2"
}

# Check if Homebrew is installed, then install if it isn't
if ! command -v brew >/dev/null 2>&1; then
    echo "🚀 Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    echo "✓ Homebrew is installed."
else
    echo "✓ Homebrew is already installed."
fi

# Install packages from Brewfile
echo "📝 Installing packages from Brewfile."
brew bundle --file="$ROOT/Brewfile"
echo "✓ Packages installed."

echo "🔄 Updating homebrew."
brew update
brew upgrade

# Clean and link dotfiles
link_file "$ROOT/dotfiles/gemrc" "$HOME/.gemrc"
link_file "$ROOT/dotfiles/gitconfig" "$HOME/.gitconfig"
link_file "$ROOT/dotfiles/gitignore" "$HOME/.gitignore"
link_file "$ROOT/dotfiles/vimrc" "$HOME/.vimrc"
link_file "$ROOT/dotfiles/zshenv" "$HOME/.zshenv"
link_file "$ROOT/dotfiles/zshrc" "$HOME/.zshrc"
link_file "$ROOT/dotfiles/zsh_plugins" "$HOME/.zsh_plugins.txt"
echo "🗂️ Dotfiles linked."

# Configure ssh to avoid typing passphrase every single time
# Modern MacOS manages ssh-agent start automatically
mkdir -p "$HOME/.ssh"
if [ ! -f "$HOME/.ssh/config" ]; then
  cat > "$HOME/.ssh/config" << 'EOL'
Host *
    AddKeysToAgent yes
    UseKeychain yes
EOL
  echo "✓ SSH config created."
else
  echo "✓ SSH config already exists."
fi

# Config Ghostty
GHOSTTY_CONFIG_DIR="$HOME/Library/Application Support/com.mitchellh.ghostty"
mkdir -p "$GHOSTTY_CONFIG_DIR"
rm -f "$GHOSTTY_CONFIG_DIR/config"
link_file "$ROOT/config/ghostty" "$GHOSTTY_CONFIG_DIR/config"
echo "✓ Ghostty configuration linked."

command -v bun >/dev/null 2>&1 || curl -fsSL https://bun.sh/install | bash
# Make bun available in this session if it was just installed
[ -s "$HOME/.bun/bin/bun" ] && export PATH="$HOME/.bun/bin:$PATH"
command -v opencode >/dev/null 2>&1 || bunx oh-my-opencode-slim@latest install

# Reload shell
echo "🔄 Reloading shell..."
exec zsh
